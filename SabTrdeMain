local function getPetInfo(data)
    local name = data.Index local rarity = "Unknown" local mpsStr = "0" local mutName = "None"
    if AnimalsData and AnimalsData[data.Index] then name = AnimalsData[data.Index].DisplayName or name rarity = AnimalsData[data.Index].Rarity or "Unknown" end
    if AnimalsShared and NumberUtils then local mpsVal = AnimalsShared:GetGeneration(data.Index, data.Mutation, data.Traits) or 0 mpsStr = NumberUtils:ToString(mpsVal) end
    if data.Mutation then if type(data.Mutation) == "string" then mutName = data.Mutation elseif type(data.Mutation) == "table" then mutName = next(data.Mutation) or "Custom" end end
    return name, rarity, mpsStr, mutName
end

